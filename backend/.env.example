PORT=3001
# Em produção (ex.: Neon), use a linha abaixo e pode omitir DB_HOST, DB_USER, etc.
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=smartbudget
JWT_SECRET=altere_este_segredo

# Telegram Bot (@BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=SeuBotSmartBudget
# URL pública do backend (produção), para registrar webhook automaticamente
TELEGRAM_WEBHOOK_URL=https://backend-beryl-seven-72ce1rm5yc.vercel.app

# WhatsApp Cloud API (opcional)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=smartbudget_verify
WHATSAPP_DISPLAY_NUMBER=

# ─── E-mail (opcional, para recuperação de senha por e-mail) ───
# Escolha UMA das opções abaixo.
#
# OPÇÃO 1 — Gmail SMTP (mais simples, gratuito):
#   1. Ative 2FA na sua conta Google: https://myaccount.google.com/security
#   2. Gere uma "Senha de aplicativo": https://myaccount.google.com/apppasswords
#   3. Preencha:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=seuemail@gmail.com
SMTP_PASS=  # senha de aplicativo (16 caracteres, sem espaços)
EMAIL_FROM=SmartBudget <seuemail@gmail.com>
#
# OPÇÃO 2 — Resend (gratuito, 100/dia, sem domínio só envia para o próprio cadastro):
#   1. Cadastre-se em https://resend.com
#   2. Em API Keys, gere uma chave
RESEND_API_KEY=
# EMAIL_FROM já é compartilhado com a opção 1 acima

# Brapi (opcional). Yahoo Finance é usado por padrão.
BRAPI_TOKEN=
